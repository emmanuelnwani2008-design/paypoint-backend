# Copy this file to .env and fill the values before running in production

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Paystack secret key (for transactions & webhook verification)
PAYSTACK_SECRET_KEY=sk_test_xxx

# Frontend and Backend public URLs
FRONTEND_URL=https://your-frontend.netlify.app
BACKEND_URL=https://your-backend.onrender.com

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://your-frontend.netlify.app,http://localhost:3000

# Optional: JWT secret if you want to verify your own tokens server-side
JWT_SECRET=some_long_random_secret

# Port (optional)
PORT=3000
# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Paystack
PAYSTACK_SECRET_KEY=

# Frontend/Backend URLs
FRONTEND_URL=
BACKEND_URL=
ALLOWED_ORIGINS=

# Optional JWT secret if you issue your own tokens
JWT_SECRET=

# Node
PORT=3000
